# Site
NEXT_PUBLIC_SITE_URL=https://rescuekits.store

# Stripe (use test keys until launch day)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (from the Stripe dashboard, per environment)
STRIPE_PRICE_CHARGEBACK=price_...
STRIPE_PRICE_GBP=price_...
STRIPE_PRICE_META=price_...
STRIPE_PRICE_STRIPE_HOLD=price_...
STRIPE_PRICE_BUNDLE=price_...
STRIPE_PRICE_BUNDLE_LAUNCH=price_... # optional €99 launch price, maps to bundle
STRIPE_PRICE_PREVENTION=price_...

# Supabase (server-side only; the browser never talks to Supabase)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Email (Resend, domain verified)
RESEND_API_KEY=re_...
EMAIL_FROM=RescueKits <access@rescuekits.store>

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXX
